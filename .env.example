DATABASE_URL=sqlite:///./lyvica.db
RESEND_API_KEY=
FROM_EMAIL=Manuel <manuel@yourdomain.com>
# AgentMail (preferred email provider — agent inbox, send + receive)
AGENTMAIL_API_KEY=
AGENTMAIL_BASE_URL=https://api.agentmail.to/v0
AGENTMAIL_INBOX_ID=
AGENTMAIL_USERNAME=
AGENTMAIL_DOMAIN=
AGENTMAIL_DISPLAY_NAME=Lyvica
STRIPE_SECRET_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_STARTER_LINK=
STRIPE_PRO_LINK=
HERMES_SHARED_SECRET=change-this
APP_BASE_URL=http://localhost:9000
GOOGLE_PLACES_API_KEY=
# Leave TELEGRAM_CHAT_ID BLANK to deliver to Hermes's home channel (the single
# source of truth: TELEGRAM_HOME_CHANNEL in ~/.hermes/.env). Only set it to
# override delivery to a specific chat/group id.
TELEGRAM_CHAT_ID=
# Scoring (merged in — no separate scoring service)
PAGESPEED_API_KEY=
GATEWAY_BASE_URL=https://gateway.truefoundry.ai/v1
GATEWAY_API_KEY=
VISION_MODEL=aws-bedrock/qwen.qwen3-vl-235b-a22b
PIPELINE_DEFAULT_CITY=San Francisco
PIPELINE_DEFAULT_INDUSTRY=dentist
PIPELINE_DEFAULT_LIMIT=10
PIPELINE_MIN_SCORE=40
# Outreach LLM (writes per-lead emails via the TrueFoundry agent virtual group)
OUTREACH_MODEL=lyvica-agent/virtual-agent-model
# Sending controls
SEND_DAILY_CAP=10
SEND_WINDOW_START=9
SEND_WINDOW_END=17
SEND_TIMEZONE=America/Los_Angeles
SEND_WEEKDAYS_ONLY=true
WARMUP_ENABLED=true
# Compliance footer (add a real street address once a virtual mailbox is set up)
COMPLIANCE_NAME=Lyvica
COMPLIANCE_WEBSITE=https://lyvica.com
COMPLIANCE_X=https://x.com/LyvicaHQ
COMPLIANCE_CITY=San Francisco, CA
COMPLIANCE_ADDRESS=
